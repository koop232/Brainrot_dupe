-- FAKE LOADING
local busy = false
local stages = {
	[1] = "Preparing Sequence",
	[25] = "Bypassing Checks",
	[50] = "Duping Assets",
	[75] = "Finalizing Clone",
	[100] = "Sequence Complete"
}

button.MouseButton1Click:Connect(function()
	if busy then
		return
	end

	busy = true
	button.Active = false
	infoText.Text = "Status: Duping"
	stageText.Text = "Preparing Sequence"
	credit.Text = "1%"
	progressFill.Size = UDim2.new(0.01, 0, 1, 0)
	scan.Visible = true

	local totalTime = 6.2
	local steps = 100

	for i = 1, steps do
		if stages[i] then
			stageText.Text = stages[i]
		end

		credit.Text = i .. "%"
		progressFill.Size = UDim2.new(i / 100, 0, 1, 0)

		if progressFill.AbsoluteSize.X > 30 then
			scan.Position = UDim2.new(1, -20, 0, 0)
		end

		if i < 100 then
			task.wait(totalTime / steps)
		end
	end

	infoText.Text = "Status: Completed"
	stageText.Text = "Awaiting Input"
	credit.Text = "Done"
	task.wait(1.1)

	infoText.Text = "Status: Idle"
	credit.Text = "Ready"
	progressFill.Size = UDim2.new(0, 0, 1, 0)
	scan.Visible = false

	button.Active = true
	busy = false
end)
